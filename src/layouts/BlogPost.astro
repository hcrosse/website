---
import BaseLayout from './BaseLayout.astro';
import Prompt from '../components/Prompt.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
}

const { title, description, date } = Astro.props;
const slug = Astro.url.pathname.replace(/^\/blog\//, '').replace(/\/$/, '');
---

<BaseLayout title={title} description={description}>
  <article>
    <header class="mb-8">
      <div class="text-sm space-y-0.5 mb-2">
        <p><Prompt cmd="cd" dir={{ href: '/blog', name: 'blog' }} /></p>
        <p>
          <Prompt
            cwd="~/blog"
            cmd="glow -s blog"
            file={{ href: `/blog/${slug}`, name: `${slug}.md` }}
          />
        </p>
      </div>
    </header>
    <div class="prose max-w-none text-sm">
      <h1 class="!mb-1">{title}</h1>
      <time
        class="text-sm text-terminal-dim block"
        datetime={date.toISOString()}
      >
        {
          date.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })
        }
      </time>
      <slot />
    </div>
  </article>
</BaseLayout>
