---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
}

const { title, description, date } = Astro.props;
const slug = Astro.url.pathname.replace(/^\/blog\//, '').replace(/\/$/, '');
---

<BaseLayout title={title} description={description}>
  <article>
    <header class="mb-8">
      <div class="text-sm space-y-0.5 mb-4">
        <p><a href="/" class="text-terminal-green hover:text-terminal-green-dim transition-colors">crosse.dev</a><span class="text-terminal-bright"> ~ $ cd </span><a href="/blog" class="text-terminal-blue font-bold hover:text-terminal-green transition-colors">blog</a></p>
        <p><a href="/" class="text-terminal-green hover:text-terminal-green-dim transition-colors">crosse.dev</a><span class="text-terminal-bright"> ~/blog $ cat </span><span class="text-terminal-yellow">{slug}.md</span></p>
      </div>
      <h1 class="text-2xl font-bold text-terminal-bright mb-2">{title}</h1>
      <time class="text-sm text-terminal-dim" datetime={date.toISOString()}>
        {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    </header>
    <div class="prose max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
