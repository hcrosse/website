---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
}

const { title, description, date } = Astro.props;
const slug = Astro.url.pathname.replace(/^\/blog\//, '').replace(/\/$/, '');
---

<BaseLayout title={title} description={description}>
  <article>
    <header class="mb-8">
      <div class="mb-4">
        <span class="text-terminal-green">$</span>
        <span class="text-terminal-bright ml-2">cat blog/{slug}.md</span>
      </div>
      <hr class="border-terminal-border mb-4" />
      <h1 class="text-2xl font-bold text-terminal-bright mb-2">{title}</h1>
      <time class="text-sm text-terminal-dim" datetime={date.toISOString()}>
        {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
    </header>
    <div class="prose max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
