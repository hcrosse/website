---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Personal website' } = Astro.props;
const year = new Date().getFullYear();
const pathname = Astro.url.pathname;

// Derive terminal path from route
function getTerminalPath(path: string): string {
  if (path === '/' || path === '') return '~';
  const clean = path.replace(/\/$/, '');
  return '~' + clean;
}

// Determine which top-level route we're on
function getActiveRoute(path: string): string {
  if (path === '/' || path === '') return '/';
  const segment = '/' + path.replace(/^\//, '').split('/')[0];
  return segment;
}

const terminalPath = getTerminalPath(pathname);
const activeRoute = getActiveRoute(pathname);

const navLinks = [
  { href: '/', label: 'home' },
  { href: '/blog', label: 'blog' },
  { href: '/work', label: 'work' },
  { href: '/contact', label: 'contact' },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <nav class="sticky top-0 z-50 border-b border-terminal-border bg-terminal-bg/90 backdrop-blur-sm px-6 py-3">
      <div class="max-w-2xl mx-auto flex items-center justify-between text-sm">
        <span class="font-bold"><a href="/" class="text-terminal-green hover:text-terminal-green-dim transition-colors">crosse.dev</a><span class="text-terminal-bright"> {terminalPath} $</span></span>
        <div class="flex gap-1">
          {navLinks
            .filter((link) => link.href !== activeRoute)
            .map((link) => (
              <a href={link.href} class="text-terminal-dim hover:text-terminal-bright transition-colors">[{link.label}]</a>
            ))
          }
        </div>
      </div>
    </nav>
    <main class="flex-1 max-w-2xl mx-auto w-full px-6 py-12">
      <slot />
    </main>
    <footer class="border-t border-terminal-border px-6 py-4">
      <div class="max-w-2xl mx-auto flex flex-col sm:flex-row sm:justify-between gap-2 text-xs text-terminal-dim">
        <span>Content licensed under <a href="https://creativecommons.org/licenses/by-nc/4.0/" class="text-terminal-dim hover:text-terminal-green transition-colors" target="_blank" rel="noopener noreferrer">CC BY-NC 4.0</a> &middot; &copy; {year}</span>
        <a href="/colophon" class="text-terminal-dim hover:text-terminal-green transition-colors">colophon</a>
      </div>
    </footer>
  </body>
</html>
