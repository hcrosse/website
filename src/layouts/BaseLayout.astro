---
import '../styles/global.css';
import Prompt from '../components/Prompt.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Personal website' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <div class="max-w-2xl mx-auto px-6">
      <div class="pt-8 text-sm">
        <p><Prompt /><span class="text-terminal-bright"> ~ $ eza</span></p>
        <p>
          <a
            href="/about"
            class="text-terminal-yellow hover:text-terminal-green transition-colors"
            >about.md</a
          >{'  '}<a
            href="/blog"
            class="text-terminal-blue font-bold hover:text-terminal-green transition-colors"
            >blog/</a
          >{'  '}<a
            href="/contact"
            class="text-terminal-yellow hover:text-terminal-green transition-colors"
            >contact.yaml</a
          >{'  '}<a
            href="/colophon"
            class="text-terminal-yellow hover:text-terminal-green transition-colors"
            >colophon.md</a
          >{'  '}<a
            href="/work"
            class="text-terminal-yellow hover:text-terminal-green transition-colors"
            >work.md</a
          >
        </p>
      </div>

      <main class="pt-8 pb-8">
        <slot />

        <div class="mt-8 text-sm">
          <Prompt /><span class="text-terminal-bright"> ~ $ </span><span
            class="cursor-blink text-terminal-bright">&#x258F;</span
          >
        </div>
      </main>
    </div>
  </body>
</html>
