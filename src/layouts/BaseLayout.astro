---
import '../styles/global.css';
import Prompt from '../components/Prompt.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Personal website' } = Astro.props;

const nav = [
  { href: '/about', name: 'about.md' },
  { href: '/blog', name: 'blog/', dir: true },
  { href: '/contact', name: 'contact.yaml' },
  { href: '/colophon', name: 'colophon.md' },
  { href: '/work', name: 'work.md' },
];
---

<html lang="en" class="loading">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>requestAnimationFrame(() => document.documentElement.classList.remove('loading'))</script>
  </head>
  <body>
    <div class="max-w-2xl mx-auto px-6">
      <div class="pt-8">
        <p><Prompt cmd="eza" /></p>
        <p>{nav.map((item, i) => <>{i > 0 && '  '}<a href={item.href} class:list={['hover:text-terminal-green transition-colors', item.dir ? 'text-terminal-blue font-bold' : 'text-terminal-yellow']}>{item.name}</a></>)}</p>
      </div>

      <main class="pt-8 pb-8">
        <slot />

        <div class="mt-8">
          <Prompt cursor />
        </div>
      </main>
    </div>
  </body>
</html>
