---
import BaseLayout from '../layouts/BaseLayout.astro';
import Prompt from '../components/Prompt.astro';
import { getEntry, render } from 'astro:content';

const page = await getEntry('pages', 'about');
const { Content } = await render(page);
---

<BaseLayout title="About">
  <div class="text-sm">
    <p><Prompt /><span class="text-terminal-bright"> ~ $ glow </span><a href="/about" class="text-terminal-yellow hover:text-terminal-green transition-colors">about.md</a></p>
  </div>
  <div class="prose prose-glow max-w-none mt-2 text-sm">
    <Content />
  </div>
</BaseLayout>
