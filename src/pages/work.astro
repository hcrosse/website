---
import BaseLayout from '../layouts/BaseLayout.astro';
import fs from 'node:fs';
import path from 'node:path';

const raw = fs.readFileSync(path.join(process.cwd(), 'src/content/pages/work.md'), 'utf-8');
const body = raw.replace(/^---[\s\S]*?---\n/, '').trim();
---

<BaseLayout title="Work">
  <div class="text-sm space-y-0.5">
    <p><a href="/" class="text-terminal-green hover:text-terminal-green-dim transition-colors">crosse.dev</a><span class="text-terminal-bright"> ~ $ cat work.md</span></p>
  </div>
  <pre class="text-sm mt-2 whitespace-pre-wrap">{body}</pre>
</BaseLayout>
