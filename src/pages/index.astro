---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, getEntry, render } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// Blog file sizes
const blogSizes = new Map<string, number>();
for (const post of posts) {
  try {
    const stat = fs.statSync(path.join(process.cwd(), 'src/content/blog', `${post.id}.md`));
    blogSizes.set(post.id, stat.size);
  } catch {
    blogSizes.set(post.id, 0);
  }
}

function formatSize(bytes: number): string {
  if (bytes >= 1024) return (bytes / 1024).toFixed(1) + 'k';
  return bytes.toString();
}

function formatDate(date: Date): string {
  const day = date.getDate().toString().padStart(2, ' ');
  const month = date.toLocaleDateString('en-US', { month: 'short' });
  const hours = date.getHours().toString().padStart(2, '0');
  const mins = date.getMinutes().toString().padStart(2, '0');
  return `${day} ${month} ${hours}:${mins}`;
}

const blogSizeStrings = posts.map((p) => formatSize(blogSizes.get(p.id) ?? 0));
const maxBlogSizeLen = Math.max(...blogSizeStrings.map((s) => s.length));

const aboutPage = await getEntry('pages', 'about');
const { Content: AboutContent } = await render(aboutPage);

const workRaw = fs.readFileSync(path.join(process.cwd(), 'src/content/pages/work.md'), 'utf-8');
const workAll = workRaw.replace(/^---[\s\S]*?---\n/, '').trim().split('\n');
const workLines = workAll.filter((line, i) => {
  if (line.trim() !== '') return true;
  const next = workAll[i + 1];
  return next && next.startsWith('## ');
}).slice(0, 6);
---

<BaseLayout title="Harrison Crosse">
  <div class="space-y-8">

    {/* about */}
    <section>
      <div class="mb-2 text-sm">
        <a href="/" class="text-terminal-green hover:text-terminal-green-dim transition-colors">crosse.dev</a><span class="text-terminal-bright"> ~ $ glow </span><a href="/about" class="text-terminal-yellow hover:text-terminal-green transition-colors">about.md</a>
      </div>
      <div class="prose prose-glow max-w-none text-sm">
        <AboutContent />
      </div>
    </section>

    {/* blog */}
    <section>
      <div class="mb-2 text-sm">
        <a href="/" class="text-terminal-green hover:text-terminal-green-dim transition-colors">crosse.dev</a><span class="text-terminal-bright"> ~ $ eza -lr -s date -t created </span><a href="/blog" class="text-terminal-blue font-bold hover:text-terminal-green transition-colors">blog/</a><span class="text-terminal-bright"> | head -3</span>
      </div>
      <ul class="space-y-0.5 text-sm">
        {posts.map((post, i) => (
          <li>
            <a href={`/blog/${post.id}`} class="group flex hover:text-terminal-green transition-colors">
              <span class="shrink-0 whitespace-pre"><span class="text-terminal-dim">.</span><span class="text-terminal-yellow">r</span><span class="text-terminal-dim">--</span><span class="text-terminal-yellow">r</span><span class="text-terminal-dim">--</span><span class="text-terminal-yellow">r</span><span class="text-terminal-dim">--</span>  <span class="text-terminal-green">{blogSizeStrings[i].padStart(maxBlogSizeLen)}</span>  <span class="text-terminal-yellow">hcrosse</span>  <span class="text-terminal-blue">{formatDate(post.data.date)}</span>  </span>
              <span class="text-terminal-yellow group-hover:text-terminal-green transition-colors truncate">{post.id}.md</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    {/* work */}
    <section>
      <div class="mb-2 text-sm">
        <a href="/" class="text-terminal-green hover:text-terminal-green-dim transition-colors">crosse.dev</a><span class="text-terminal-bright"> ~ $ glow </span><a href="/work" class="text-terminal-yellow hover:text-terminal-green transition-colors">work.md</a><span class="text-terminal-bright"> | head -6</span>
      </div>
      <div class="text-sm">
        {workLines.map((line) => {
          if (line.startsWith('## ')) {
            return <p class="text-terminal-blue font-bold">{line}</p>;
          }
          if (line.trim() === '') {
            return <p>&nbsp;</p>;
          }
          return <p>{line}</p>;
        })}
      </div>
    </section>

    {/* contact */}
    <section>
      <div class="mb-2 text-sm">
        <a href="/" class="text-terminal-green hover:text-terminal-green-dim transition-colors">crosse.dev</a><span class="text-terminal-bright"> ~ $ glow </span><a href="/contact" class="text-terminal-yellow hover:text-terminal-green transition-colors">contact.yaml</a>
      </div>
      <ul class="space-y-0.5 text-sm">
        <li class="flex"><span class="text-terminal-blue w-[10ch]">email:</span><a href="mailto:harrison@crosse.dev" class="text-terminal-text hover:text-terminal-green transition-colors">harrison@crosse.dev</a></li>
        <li class="flex"><span class="text-terminal-blue w-[10ch]">github:</span><a href="https://github.com/hcrosse" class="text-terminal-text hover:text-terminal-green transition-colors" target="_blank" rel="noopener noreferrer">https://github.com/hcrosse</a></li>
        <li class="flex"><span class="text-terminal-blue w-[10ch]">linkedin:</span><a href="https://linkedin.com/in/hcrosse" class="text-terminal-text hover:text-terminal-green transition-colors" target="_blank" rel="noopener noreferrer">https://linkedin.com/in/hcrosse</a></li>
      </ul>
    </section>

  </div>
</BaseLayout>
