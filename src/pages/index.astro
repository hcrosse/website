---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';
import fs from 'node:fs';
import ContactList from '../components/ContactList.astro';
import BlogListing from '../components/BlogListing.astro';
import Prompt from '../components/Prompt.astro';

const aboutPage = await getEntry('pages', 'about');
const { Content: AboutContent } = await render(aboutPage);

const workRaw = fs.readFileSync(
  `${process.cwd()}/src/content/pages/work.md`,
  'utf-8',
);
const workAll = workRaw
  .replace(/^---[\s\S]*?---\n/, '')
  .trim()
  .split('\n');
const workLines = workAll
  .filter((line, i) => {
    if (line.trim() !== '') return true;
    const next = workAll[i + 1];
    return next && next.startsWith('## ');
  })
  .slice(0, 6);
---

<BaseLayout
  title="Harrison Crosse"
  description="Harrison Crosse — software engineer building data infrastructure and tooling."
>
  <script
    slot="head"
    type="application/ld+json"
    set:text={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: 'Harrison Crosse',
      url: 'https://crosse.dev',
      email: 'harrison@crosse.dev',
      sameAs: ['https://github.com/hcrosse', 'https://linkedin.com/in/hcrosse'],
    })}
  />
  <div class="space-y-8">
    {/* about */}
    <section>
      <Prompt cmd="glow" file={{ href: '/about', name: 'about.md' }} />
      <div class="prose prose-glow max-w-none mt-2">
        <AboutContent />
      </div>
    </section>

    {/* blog */}
    <section>
      <Prompt
        cmd="eza -lr -s date -t created"
        dir={{ href: '/blog', name: 'blog/' }}
        suffix="| head -3"
      />
      <div class="mt-2">
        <BlogListing limit={3} />
      </div>
    </section>

    {/* work */}
    <section>
      <Prompt
        cmd="glow"
        file={{ href: '/work', name: 'work.md' }}
        suffix="| head -6"
      />
      <div class="mt-2">
        {
          workLines.map((line) => {
            if (line.startsWith('## ')) {
              return <p class="text-terminal-blue font-bold">{line}</p>;
            }
            if (line.trim() === '') {
              return <p>&nbsp;</p>;
            }
            return <p>{line}</p>;
          })
        }
      </div>
    </section>

    {/* contact */}
    <section>
      <Prompt cmd="bat -pp" file={{ href: '/contact', name: 'contact.yaml' }} />
      <div class="mt-2">
        <ContactList />
      </div>
    </section>
  </div>
</BaseLayout>
