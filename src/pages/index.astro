---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// Blog file sizes
const blogSizes = new Map<string, number>();
for (const post of posts) {
  try {
    const stat = fs.statSync(path.join(process.cwd(), 'src/content/blog', `${post.id}.md`));
    blogSizes.set(post.id, stat.size);
  } catch {
    blogSizes.set(post.id, 0);
  }
}

function formatSize(bytes: number): string {
  if (bytes >= 1024) return (bytes / 1024).toFixed(1) + 'k';
  return bytes.toString();
}

function formatDate(date: Date): string {
  const day = date.getDate().toString().padStart(2, ' ');
  const month = date.toLocaleDateString('en-US', { month: 'short' });
  const hours = date.getHours().toString().padStart(2, '0');
  const mins = date.getMinutes().toString().padStart(2, '0');
  return `${day} ${month} ${hours}:${mins}`;
}

const blogSizeStrings = posts.map((p) => formatSize(blogSizes.get(p.id) ?? 0));
const maxBlogSizeLen = Math.max(...blogSizeStrings.map((s) => s.length));

const workRaw = fs.readFileSync(path.join(process.cwd(), 'src/content/pages/work.md'), 'utf-8');
const workBody = workRaw.replace(/^---[\s\S]*?---\n/, '').trim();
const workHead = workBody.split('\n').slice(0, 6).join('\n');
---

<BaseLayout title="Harrison Crosse">
  <div class="space-y-16">

    {/* about */}
    <section>
      <div class="mb-3">
        <span class="text-terminal-green">$</span>
        <span class="text-terminal-bright ml-2">cat about.md</span>
      </div>
      <hr class="border-terminal-border mb-4" />
      <p class="leading-relaxed">
        Hey, I'm Harrison. I'm a software engineer who likes building things.
        Welcome to my corner of the internet.
      </p>
    </section>

    {/* blog */}
    <section>
      <div class="mb-3">
        <span class="text-terminal-green">$</span>
        <span class="text-terminal-bright ml-2">ls -lt blog/ | head -3</span>
      </div>
      <hr class="border-terminal-border mb-4" />
      <ul class="space-y-0.5 text-sm">
        {posts.map((post, i) => (
          <li>
            <a href={`/blog/${post.id}`} class="group flex hover:text-terminal-green transition-colors">
              <span class="shrink-0 whitespace-pre"><span class="text-terminal-dim">.</span><span class="text-terminal-yellow">r</span><span class="text-terminal-dim">--</span><span class="text-terminal-yellow">r</span><span class="text-terminal-dim">--</span><span class="text-terminal-yellow">r</span><span class="text-terminal-dim">--</span>  <span class="text-terminal-green">{blogSizeStrings[i].padStart(maxBlogSizeLen)}</span>  <span class="text-terminal-yellow">hcrosse</span>  <span class="text-terminal-blue">{formatDate(post.data.date)}</span>  </span>
              <span class="text-terminal-text group-hover:text-terminal-green transition-colors truncate">{post.data.title}</span>
            </a>
          </li>
        ))}
      </ul>
      <a href="/blog" class="inline-block mt-4 text-sm text-terminal-dim hover:text-terminal-green transition-colors">
        → view all posts
      </a>
    </section>

    {/* work */}
    <section>
      <div class="mb-3">
        <span class="text-terminal-green">$</span>
        <span class="text-terminal-bright ml-2">head -6 work.md</span>
      </div>
      <hr class="border-terminal-border mb-4" />
      <pre class="text-sm whitespace-pre-wrap">{workHead}</pre>
      <a href="/work" class="inline-block mt-4 text-sm text-terminal-dim hover:text-terminal-green transition-colors">
        → view all
      </a>
    </section>

    {/* contact */}
    <section>
      <div class="mb-3">
        <span class="text-terminal-green">$</span>
        <span class="text-terminal-bright ml-2">cat contact.info</span>
      </div>
      <hr class="border-terminal-border mb-4" />
      <ul class="space-y-0.5 text-sm">
        <li class="flex"><span class="text-terminal-dim w-[10ch]">github:</span><a href="https://github.com/hcrosse" class="text-terminal-text hover:text-terminal-green transition-colors" target="_blank" rel="noopener noreferrer">https://github.com/hcrosse</a></li>
        <li class="flex"><span class="text-terminal-dim w-[10ch]">linkedin:</span><a href="https://linkedin.com/in/hcrosse" class="text-terminal-text hover:text-terminal-green transition-colors" target="_blank" rel="noopener noreferrer">https://linkedin.com/in/hcrosse</a></li>
      </ul>
    </section>

  </div>
</BaseLayout>
