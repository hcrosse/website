---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Blog">
  <div class="mb-3">
    <span class="text-terminal-green">$</span>
    <span class="text-terminal-bright ml-2">ls blog/</span>
  </div>
  <hr class="border-terminal-border mb-8" />
  <ul class="space-y-4">
    {posts.map((post) => (
      <li>
        <a href={`/blog/${post.id}`} class="group block">
          <div class="flex items-baseline gap-3">
            <time
              class="text-terminal-dim text-sm shrink-0"
              datetime={post.data.date.toISOString()}
            >
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
            <h2 class="text-terminal-text group-hover:text-terminal-green transition-colors">
              {post.data.title}
            </h2>
          </div>
          {post.data.description && (
            <p class="text-terminal-dim text-sm mt-1 ml-0 sm:ml-[calc(theme(spacing.3)+7ch)]">
              {post.data.description}
            </p>
          )}
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
