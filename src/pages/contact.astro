---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact">
  <div class="text-sm">
    <p><span class="text-terminal-green">crosse.dev</span><span class="text-terminal-bright"> ~ $ bat contact.yaml</span></p>
  </div>
  <div class="text-sm mt-2">
    <ul class="space-y-0.5">
      <li class="flex"><span class="text-terminal-blue w-[10ch]">github:</span><a href="https://github.com/hcrosse" class="text-terminal-text hover:text-terminal-green transition-colors" target="_blank" rel="noopener noreferrer">https://github.com/hcrosse</a></li>
      <li class="flex"><span class="text-terminal-blue w-[10ch]">linkedin:</span><a href="https://linkedin.com/in/hcrosse" class="text-terminal-text hover:text-terminal-green transition-colors" target="_blank" rel="noopener noreferrer">https://linkedin.com/in/hcrosse</a></li>
    </ul>
  </div>
</BaseLayout>
