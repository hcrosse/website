---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Colophon">
  <div class="text-sm mb-8">
    <p><span class="text-terminal-green">crosse.dev</span><span class="text-terminal-bright"> ~ $ bat colophon.md</span></p>
  </div>

  <div class="space-y-10">

    <section>
      <h2 class="text-terminal-bright font-bold mb-2">License</h2>
      <p>
        Content on this site is released under the
        <a href="https://creativecommons.org/licenses/by-nc/4.0/" class="text-terminal-green hover:text-terminal-green-dim transition-colors" target="_blank" rel="noopener noreferrer">Creative Commons BY-NC 4.0</a>
        license, except where stated otherwise. &copy; {new Date().getFullYear()} Harrison Crosse.
      </p>
    </section>

    <section>
      <h2 class="text-terminal-bright font-bold mb-2">Typography</h2>
      <p>
        <span class="text-terminal-green">Berkeley Mono</span> by Neil Kummerfeld /
        <a href="https://usgraphics.com" class="text-terminal-green hover:text-terminal-green-dim transition-colors" target="_blank" rel="noopener noreferrer">US Graphics</a>
      </p>
    </section>

    <section>
      <h2 class="text-terminal-bright font-bold mb-2">Colors</h2>
      <ul class="space-y-1 text-sm">
        <li><span class="inline-block w-3 h-3 rounded-sm mr-2 align-middle" style="background:#1e1e2e;border:1px solid #45475a"></span><span class="text-terminal-dim">Base</span> <span class="text-terminal-text">#1e1e2e</span></li>
        <li><span class="inline-block w-3 h-3 rounded-sm mr-2 align-middle" style="background:#313244;border:1px solid #45475a"></span><span class="text-terminal-dim">Surface</span> <span class="text-terminal-text">#313244</span></li>
        <li><span class="inline-block w-3 h-3 rounded-sm mr-2 align-middle" style="background:#cdd6f4"></span><span class="text-terminal-dim">Text</span> <span class="text-terminal-text">#cdd6f4</span></li>
        <li><span class="inline-block w-3 h-3 rounded-sm mr-2 align-middle" style="background:#bac2de"></span><span class="text-terminal-dim">Subtext</span> <span class="text-terminal-text">#bac2de</span></li>
        <li><span class="inline-block w-3 h-3 rounded-sm mr-2 align-middle" style="background:#20c20e"></span><span class="text-terminal-dim">Green</span> <span class="text-terminal-text">#20c20e</span></li>
        <li><span class="inline-block w-3 h-3 rounded-sm mr-2 align-middle" style="background:#6c7086"></span><span class="text-terminal-dim">Overlay</span> <span class="text-terminal-text">#6c7086</span></li>
        <li><span class="inline-block w-3 h-3 rounded-sm mr-2 align-middle" style="background:#45475a;border:1px solid #585b70"></span><span class="text-terminal-dim">Border</span> <span class="text-terminal-text">#45475a</span></li>
      </ul>
    </section>

    <section>
      <h2 class="text-terminal-bright font-bold mb-2">Built with</h2>
      <ul class="space-y-1">
        <li><a href="https://astro.build" class="text-terminal-green hover:text-terminal-green-dim transition-colors" target="_blank" rel="noopener noreferrer">Astro</a></li>
        <li><a href="https://tailwindcss.com" class="text-terminal-green hover:text-terminal-green-dim transition-colors" target="_blank" rel="noopener noreferrer">Tailwind CSS</a></li>
        <li>Deployed on <a href="https://pages.github.com" class="text-terminal-green hover:text-terminal-green-dim transition-colors" target="_blank" rel="noopener noreferrer">GitHub Pages</a></li>
      </ul>
    </section>

    <section>
      <h2 class="text-terminal-bright font-bold mb-2">Source</h2>
      <p>
        <a href="https://github.com/hcrosse/website" class="text-terminal-green hover:text-terminal-green-dim transition-colors" target="_blank" rel="noopener noreferrer">github.com/hcrosse/website</a>
      </p>
    </section>

  </div>
</BaseLayout>
